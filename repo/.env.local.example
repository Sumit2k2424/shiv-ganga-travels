# ─── Google Places API (for live Google Reviews on homepage) ───────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a project (or use existing one)
# 3. Enable "Places API" at https://console.cloud.google.com/apis/library
# 4. Create an API Key → restrict it to "Places API" + your domain
# 5. Paste the key below
#
# Cost: Free tier covers ~40,000 place details requests/month
# Place ID for Shiv Ganga Travels: ChIJcbRpbaBHCTkRsh3aBCyZEt8
#
GOOGLE_PLACES_API_KEY=your_api_key_here

# ─── Claude API (chatbot AI fallback) ──────────────────────────────────────
# Required for the chatbot's AI answers. Used server-side only by
# /src/app/api/chat/route.js — the browser never sees this key.
# Set it in Vercel → Project → Settings → Environment Variables.
# ANTHROPIC_API_KEY=your_key_here
